;; ooyake 公 — gov-procedures.bpmn.edn
;;
;; Phase 2 BPMN process models for toritsugi's 6 R0 procedures, per ADR-2606021600
;; (+ toritsugi ADR-2605312030). Each :bpmn/id replaces the prior
;; "bpmn.ooyake.find-service" STUB on the matching :gov.procedure/bpmn in
;; gov-units.seed.edn (3) and gov-units.toritsugi-procedures.seed.edn (3).
;;
;; FORMAT: BPMN-as-edn (org-omg-bpmn / bpmn-clj R1 working .cljc). Node-type
;; keywords restricted to the valid set: :start-event / :end-event /
;; :service-task / :user-task / :script-task / :exclusive-gateway /
;; :parallel-gateway / :inclusive-gateway.
;;
;; SOURCE (no fabrication, G5): every process step is DERIVED from the
;; corresponding :gov.procedure's {legal-basis, required-docs, fee,
;; statutory-days, provenance} in the seed — the identity-verification step comes
;; from required-docs "本人確認書類", the fee-payment step from :gov.procedure/fee,
;; the statutory waiting window from :gov.procedure/statutory-days, and so on.
;; :bpmn/legal-basis and :bpmn/provenance are COPIED verbatim from the seed (same
;; G5 provenance string), never invented. Conservative minimal steps where the
;; seed does not justify more detail.

{:graph {:name "gov-atlas-v1" :visibility :public}

 :processes
 [;; ── 1. 住民票の写し交付請求 (Copy of resident record) ─────────────────────────
  ;; derived from: 住民基本台帳法 §12; required-docs [本人確認書類, (コンビニ交付)
  ;; マイナンバーカード+暗証番号]; fee JPY 300 (自治体により 200-400); statutory-days 0.
  ;; steps: 受付 → 本人確認 → 手数料納付 → 交付
  {:bpmn/id "bpmn.ooyake.proc.jpn.juminhyo-utsushi"
   :bpmn/type :process
   :bpmn/name "住民票の写し交付請求 (Request for copy of resident record — citizen-procedure process model)"
   :bpmn/executable true
   :bpmn/legal-basis "住民基本台帳法 §12"
   :bpmn/provenance "https://www.soumu.go.jp/main_sosiki/jichi_gyousei/c-gyousei/zairyu/juuki.html"
   :bpmn/nodes {"S"     {:bpmn/id "S"     :bpmn/type :start-event  :bpmn/name "申請受付 (Application received)"}
                "T_idv" {:bpmn/id "T_idv" :bpmn/type :user-task    :bpmn/name "本人確認書類提示 (Identity verification documents presented)"}
                "T_fee" {:bpmn/id "T_fee" :bpmn/type :service-task :bpmn/name "手数料納付 — JPY 300 程度 (Fee payment per 自治体 fee schedule)"}
                "E"     {:bpmn/id "E"     :bpmn/type :end-event    :bpmn/name "住民票の写し交付 (Copy of resident record issued)"}}
   :bpmn/flows {"F1" {:bpmn/id "F1" :bpmn/type :sequence-flow :bpmn/source "S"     :bpmn/target "T_idv"}
                "F2" {:bpmn/id "F2" :bpmn/type :sequence-flow :bpmn/source "T_idv" :bpmn/target "T_fee"}
                "F3" {:bpmn/id "F3" :bpmn/type :sequence-flow :bpmn/source "T_fee" :bpmn/target "E"}}}

  ;; ── 2. 転入届 (Notification of moving-in) ──────────────────────────────────
  ;; derived from: 住民基本台帳法 §22; required-docs [転出証明書, 本人確認書類,
  ;; マイナンバーカード or 通知カード]; fee 無料; statutory-days 0.
  ;; steps: 受付 → 本人確認(+転出証明書) → 転入登録 → 住民票反映 → 受理
  {:bpmn/id "bpmn.ooyake.proc.jpn.tennyu-todoke"
   :bpmn/type :process
   :bpmn/name "転入届 (Notification of moving-in — citizen-procedure process model)"
   :bpmn/executable true
   :bpmn/legal-basis "住民基本台帳法 §22"
   :bpmn/provenance "https://www.soumu.go.jp/main_sosiki/jichi_gyousei/c-gyousei/zairyu/index.html"
   :bpmn/nodes {"S"      {:bpmn/id "S"      :bpmn/type :start-event  :bpmn/name "届出受付 (Notification received)"}
                "T_idv"  {:bpmn/id "T_idv"  :bpmn/type :user-task    :bpmn/name "本人確認書類提示 + 転出証明書提出 (Identity verification + move-out certificate presented)"}
                "T_reg"  {:bpmn/id "T_reg"  :bpmn/type :service-task :bpmn/name "転入登録 (Move-in registration per 住民基本台帳法 §22)"}
                "T_upd"  {:bpmn/id "T_upd"  :bpmn/type :service-task :bpmn/name "住民票登録反映 (Resident record updated)"}
                "E"      {:bpmn/id "E"      :bpmn/type :end-event    :bpmn/name "受理・登録完了 (Accepted & registration completed)"}}
   :bpmn/flows {"F1" {:bpmn/id "F1" :bpmn/type :sequence-flow :bpmn/source "S"     :bpmn/target "T_idv"}
                "F2" {:bpmn/id "F2" :bpmn/type :sequence-flow :bpmn/source "T_idv" :bpmn/target "T_reg"}
                "F3" {:bpmn/id "F3" :bpmn/type :sequence-flow :bpmn/source "T_reg" :bpmn/target "T_upd"}
                "F4" {:bpmn/id "F4" :bpmn/type :sequence-flow :bpmn/source "T_upd" :bpmn/target "E"}}}

  ;; ── 3. 出生届 (Birth notification) ─────────────────────────────────────────
  ;; derived from: 戸籍法 §49; required-docs [出生届書(医師・助産師の出生証明欄記入済),
  ;; 母子健康手帳, 届出人の本人確認書類]; fee 無料; statutory-days 0.
  ;; steps: 届出 → 出生証明欄(医師/助産師)確認 → 母子健康手帳提示 → 受理(法定0日)
  {:bpmn/id "bpmn.ooyake.proc.jpn.shussei-todoke"
   :bpmn/type :process
   :bpmn/name "出生届 (Birth notification — citizen-procedure process model)"
   :bpmn/executable true
   :bpmn/legal-basis "戸籍法 §49"
   :bpmn/provenance "https://www.moj.go.jp/MINJI/minji01_00001.html"
   :bpmn/nodes {"S"       {:bpmn/id "S"       :bpmn/type :start-event  :bpmn/name "届出受付 (Notification submitted)"}
                "T_cert"  {:bpmn/id "T_cert"  :bpmn/type :service-task :bpmn/name "出生証明欄確認 — 医師/助産師署名 (Birth certificate section verified — physician/midwife signature)"}
                "T_boshi" {:bpmn/id "T_boshi" :bpmn/type :user-task    :bpmn/name "母子健康手帳提示 (Maternal and child health handbook presented)"}
                "E"       {:bpmn/id "E"       :bpmn/type :end-event    :bpmn/name "届出受理 (Notification accepted per 戸籍法 §49, 法定0日)"}}
   :bpmn/flows {"F1" {:bpmn/id "F1" :bpmn/type :sequence-flow :bpmn/source "S"       :bpmn/target "T_cert"}
                "F2" {:bpmn/id "F2" :bpmn/type :sequence-flow :bpmn/source "T_cert"  :bpmn/target "T_boshi"}
                "F3" {:bpmn/id "F3" :bpmn/type :sequence-flow :bpmn/source "T_boshi" :bpmn/target "E"}}}

  ;; ── 4. マイナンバーカード 交付申請 (My Number card issuance) ─────────────────
  ;; derived from: 番号法 §17; required-docs [交付申請書(個人番号通知書/QR 付き),
  ;; 顔写真(規格準拠), (交付時)本人確認書類]; fee 無料(初回); statutory-days 30.
  ;; steps: 交付申請(QR/書式) → 顔写真 → 審査・カード作成(法定30日) → 交付窓口で本人確認・受領
  {:bpmn/id "bpmn.ooyake.proc.jpn.mynumber-card"
   :bpmn/type :process
   :bpmn/name "マイナンバーカード 交付申請 (My Number card issuance — citizen-procedure process model)"
   :bpmn/executable true
   :bpmn/legal-basis "行政手続における特定の個人を識別するための番号の利用等に関する法律 (番号法) §17"
   :bpmn/provenance "https://www.kojinbango-card.go.jp/ (所管: J-LIS + 市区町村)"
   :bpmn/nodes {"S"         {:bpmn/id "S"         :bpmn/type :start-event  :bpmn/name "交付申請受付 — QR/書式 (Application received via QR / paper form)"}
                "T_photo"   {:bpmn/id "T_photo"   :bpmn/type :user-task    :bpmn/name "顔写真提出 — 規格準拠 (Face photo submitted per spec)"}
                "T_review"  {:bpmn/id "T_review"  :bpmn/type :service-task :bpmn/name "審査・カード作成 — 法定30日 (Review & card production per 番号法 §17, statutory 30 days)"}
                "T_receive" {:bpmn/id "T_receive" :bpmn/type :user-task    :bpmn/name "交付窓口で本人確認・受領 (Identity verification & receipt at issuance window)"}
                "E"         {:bpmn/id "E"         :bpmn/type :end-event    :bpmn/name "カード交付完了 (Card issued)"}}
   :bpmn/flows {"F1" {:bpmn/id "F1" :bpmn/type :sequence-flow :bpmn/source "S"         :bpmn/target "T_photo"}
                "F2" {:bpmn/id "F2" :bpmn/type :sequence-flow :bpmn/source "T_photo"   :bpmn/target "T_review"}
                "F3" {:bpmn/id "F3" :bpmn/type :sequence-flow :bpmn/source "T_review"  :bpmn/target "T_receive"}
                "F4" {:bpmn/id "F4" :bpmn/type :sequence-flow :bpmn/source "T_receive" :bpmn/target "E"}}}

  ;; ── 5. 児童手当 認定請求 (Child allowance certification request) ─────────────
  ;; derived from: 児童手当法 §7; required-docs [認定請求書, 請求者名義の振込先口座,
  ;; 請求者の健康保険証(写し), 本人確認書類]; fee 無料; statutory-days 0.
  ;; steps: 認定請求 → 必要書類確認 → 請求者特定(振込口座/保険証) → 審査 → 認定・振込登録
  {:bpmn/id "bpmn.ooyake.proc.jpn.jido-teate"
   :bpmn/type :process
   :bpmn/name "児童手当 認定請求 (Child allowance certification request — citizen-procedure process model)"
   :bpmn/executable true
   :bpmn/legal-basis "児童手当法 §7"
   :bpmn/provenance "https://www.cfa.go.jp/policies/kokoseido/jidouteate/annai/"
   :bpmn/nodes {"S"        {:bpmn/id "S"        :bpmn/type :start-event  :bpmn/name "認定請求受付 (Certification request received)"}
                "T_docs"   {:bpmn/id "T_docs"   :bpmn/type :user-task    :bpmn/name "必要書類確認 — 認定請求書 + 本人確認書類 (Required documents checked)"}
                "T_req"    {:bpmn/id "T_req"    :bpmn/type :service-task :bpmn/name "請求者特定 — 振込口座 / 健康保険証(写し) (Requester identification: bank account / health insurance certificate)"}
                "T_review" {:bpmn/id "T_review" :bpmn/type :service-task :bpmn/name "審査 (Review per 児童手当法 §7)"}
                "E"        {:bpmn/id "E"        :bpmn/type :end-event    :bpmn/name "認定・振込登録 (Certified & payment registration completed)"}}
   :bpmn/flows {"F1" {:bpmn/id "F1" :bpmn/type :sequence-flow :bpmn/source "S"        :bpmn/target "T_docs"}
                "F2" {:bpmn/id "F2" :bpmn/type :sequence-flow :bpmn/source "T_docs"   :bpmn/target "T_req"}
                "F3" {:bpmn/id "F3" :bpmn/type :sequence-flow :bpmn/source "T_req"    :bpmn/target "T_review"}
                "F4" {:bpmn/id "F4" :bpmn/type :sequence-flow :bpmn/source "T_review" :bpmn/target "E"}}}

  ;; ── 6. 確定申告 e-Tax (Income tax final return via e-Tax) ───────────────────
  ;; derived from: 所得税法 §120; required-docs [源泉徴収票/収入・経費記録,
  ;; 各種控除証明書, マイナンバーカード(e-Tax 認証)]; fee 無料; statutory-days 0.
  ;; steps: e-Tax 入力 → 送信 → 受理通知
  {:bpmn/id "bpmn.ooyake.proc.jpn.kakutei-shinkoku-etax"
   :bpmn/type :process
   :bpmn/name "確定申告 e-Tax (Income tax final return via e-Tax — citizen-procedure process model)"
   :bpmn/executable true
   :bpmn/legal-basis "所得税法 §120"
   :bpmn/provenance "https://www.nta.go.jp/taxes/shiraberu/shinkoku/kakutei.htm"
   :bpmn/nodes {"S"      {:bpmn/id "S"      :bpmn/type :start-event  :bpmn/name "e-Tax 入力 — 所得・控除データ (e-Tax data entry: income & deduction records)"}
                "T_send" {:bpmn/id "T_send" :bpmn/type :service-task :bpmn/name "送信 — 所得税法 §120 (Submit final return per 所得税法 §120)"}
                "E"      {:bpmn/id "E"      :bpmn/type :end-event    :bpmn/name "受理通知 (Acceptance notice received)"}}
   :bpmn/flows {"F1" {:bpmn/id "F1" :bpmn/type :sequence-flow :bpmn/source "S"      :bpmn/target "T_send"}
                "F2" {:bpmn/id "F2" :bpmn/type :sequence-flow :bpmn/source "T_send" :bpmn/target "E"}}}]}

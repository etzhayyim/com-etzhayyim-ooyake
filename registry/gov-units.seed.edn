;; ooyake 公 — gov-units.seed.edn
;;
;; R0 PROOF-OF-MODEL seed for the world government atlas, per ADR-2606021600.
;; Vocabulary: 00-contracts/schemas/gov-atlas-ontology.kotoba.edn (:gov.*).
;;
;; THIS IS A PROOF-OF-MODEL, NOT COVERAGE. It demonstrates the full chain
;; (country → ministry → agency → regional bureau → 税務署 with 窓口/住所; and
;; prefecture → 特別区 → 窓口 with 住所; procedures with 書式 + BPMN + toritsugi
;; linkage) end-to-end on kotoba EDN, plus several country/ministry rows for other
;; nations. EVERY row ships :sourcing :representative + :verification-status
;; :unverified-seed (G5): the addresses/codes/hours below are BEST-EFFORT public
;; references as of 2026-06-02 and are EXPECTED to drift. NO downstream actor
;; (esp. toritsugi G14) may act on an :unverified-seed/:representative row — they
;; must be maintainer-verified (→ :authoritative) within the freshness window first.
;;
;; Atlas DIDs (did:web:etzhayyim.com:gov:...) are OBSERVATIONAL MIRRORS (G3): they
;; identify ooyake's mirror record of a real public body, NEVER claim to BE it,
;; NEVER an official channel.

{:graph {:name "gov-atlas-v1"
         :cid :derived ;; KotobaCid::from_bytes(b"gov-atlas-v1") at boot
         :visibility :public}

 ;; ── schema install tx (run once by publisher before first upsert) ───────────
 :schema-tx
 [{:db/id ":gov.unit/id"      :db/ident :gov.unit/id      :db/unique :db.unique/identity}
  {:db/id ":gov.unit/atlas-did" :db/ident :gov.unit/atlas-did :db/unique :db.unique/identity}
  {:db/id ":gov.address/id"   :db/ident :gov.address/id   :db/unique :db.unique/identity}
  {:db/id ":gov.window/id"    :db/ident :gov.window/id    :db/unique :db.unique/identity}
  {:db/id ":gov.procedure/id" :db/ident :gov.procedure/id :db/unique :db.unique/identity}
  {:db/id ":gov.form/id"      :db/ident :gov.form/id      :db/unique :db.unique/identity}
  {:db/id ":gov.bpmn/id"      :db/ident :gov.bpmn/id      :db/unique :db.unique/identity}]


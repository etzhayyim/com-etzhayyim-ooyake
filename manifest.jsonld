  "tier": "Tier-B",
  "parentActor": null,
  "posture": "READ-SIDE structural atlas + civic wayfinding map (observational mirror). NEVER an official channel, NEVER files/submits, NEVER audits — those are toritsugi (gated) and danjo respectively.",
  "primarySchema": "00-contracts/schemas/gov-atlas-ontology.kotoba.edn",
  "crossActorBoundary": [
    "did:web:toritsugi.etzhayyim.com (BOUNDARY: ooyake CATALOGS who/where/structure of a procedure; toritsugi DELIVERS it to the citizen [guide/draft/submit/track]. :gov.procedure/toritsugi-ref links each procedure to com.etzhayyim.toritsugi.procedure; no duplication; ADR-2605312030)",
    "did:web:chigiri.etzhayyim.com (BOUNDARY: chigiri OWNS the UPL-bounded fillable form templates; ooyake only points at them via :gov.form/chigiri-ref; ADR-2605262700)",
    "did:web:danjo.etzhayyim.com (BOUNDARY: danjo AUDITS/cross-references state open-data; ooyake only MAPS structure. danjo consumes the atlas; ADR-2605301600)",
    "did:web:kanae.etzhayyim.com (kanae renders fiscal flows over units the atlas enumerates; ADR-2605302300)",
    "did:web:tsumugi.etzhayyim.com (BOUNDARY: tsumugi weaves 縁/取 karma over :organism nodes; ooyake maps structure. :gov.unit/organism reconciles the SAME unit across both graphs [atlas=structure, engi=karma]; ADR-2606011800 + 2606011000)",
    "did:web:himotoki.etzhayyim.com (himotoki resolves WHICH authority + 窓口 to file a 開示請求/FOIA against via the atlas; ADR-2605302130)",
    "kotoba QuadStore EAVT (gov-atlas-v1 graph: :gov.unit/:gov.address/:gov.window/:gov.form/:gov.procedure/:gov.bpmn datoms; ADR-2605262130 + 2605312345; no RisingWave / no projection layer)",
    "00-contracts/bpmn/com/etzhayyim/gov*/ (LEGACY F-Plan country BPMN stubs + 90-docs/openapi/gov*.openapi.json: SUBSUMED by ooyake's :gov.* graph as kotoba-native owner; com.etzhayyim.gov* → com.etzhayyim.ooyake.* rename deferred to the gated Step-8 etzhayyim-* cutover, NOT executed here)"
  ],
  "form": "任意団体 internal civic-knowledge substrate (NOT a government, NOT an official 自治体/省庁 channel — observational mirror only, G3/§2(c); NOT a 行政書士/弁護士 firm; NOT a data-broker product — public good, G8). Preamble §0.4 Lv7+ unanimity lock applies.",
  "constitutionalDiscipline": {
    "observationalMirrorOnly": "G3 — the per-unit atlas DID (did:web:etzhayyim.com:gov:<iso3>:...) is an etzhayyim MIRROR of a real public body; it NEVER claims to BE the government, NEVER is an official channel, NEVER issues/accepts anything on a government's behalf (§2(c) impersonation ban). The DID-doc declares the mirror relation + links the body's official-url / official-did.",
    "publicDataOnly": "G4 — only public official sources; respect robots.txt / ToS / rate-limits; no behind-auth access; no circumvention.",
    "nonFabrication": "G5 — every unit/address/window/form/procedure carries provenance + last-verified + sourcing (:authoritative | :representative); :representative rows are illustrative and NEVER counted as coverage; procedures must cite legal-basis.",
    "noPersonalData": "G6 — government org data + public role-contact (switchboard / 窓口) only; NEVER an individual official's private/home contact; data-minimized.",
    "murakumoOnlyInference": "G7 — Murakumo-only inference (ADR-2605215000).",
    "nonCommercial": "G8 — non-profit public good; no resale of the atlas as a data product (Charter Rider §2(e)).",
    "readSideOnly": "G9 — ooyake never files/submits/mutates a government record (→ toritsugi, gated) and never audits/adjudicates (→ danjo).",
    "civicWayfindingNotTargetList": "G10 — a map to help a citizen FIND a service; NEVER an attack-surface / SPOF / weak-point map of the state (Transparent Force discipline, §1.12).",
    "neutrality": "G11 — jurisdiction-neutral + politically neutral; descriptive only; no ranking of governments.",
    "freshnessGated": "G12 — stale entries flagged :stale; downstream consumers (esp. toritsugi G14) MUST re-verify before any citizen-facing action."
  },
  "scope": {
    "phase": "R0 scaffold",
    "scopeBoundary": "World government-unit STRUCTURAL atlas: recursive administrative tree + 住所 + 窓口 + 書式 + 手続き + BPMN + civic wayfinding (getUnit / resolvePath / findService / searchUnits), kotoba-Datomic-native, read-only. JP-first proof-of-model; jurisdiction-generic architecture.",
    "exclusions": [
      "a government / official 自治体・省庁 channel (observational mirror only, G3)",
      "a filing / submission actor (that is toritsugi, gated)",
      "an oversight / audit / adjudication actor (that is danjo)",
      "a fiscal-flow visualizer (that is kanae)",
      "a 縁/取 karma power-graph (that is tsumugi; ooyake maps structure, reconciles via :gov.unit/organism)",
      "an attack-surface / SPOF / weak-point map of the state (G10)",
      "a store of officials' personal data (G6)",
      "a data-broker / resold data product (G8)",
      "a 行政書士 / 弁護士 firm or legal/tax advice (→ chigiri / toritate / licensed)",
      "a closed-source / secret-method engine",
      "complete coverage (R0 is a proof-of-model; coverage gated by :sourcing, G5)"
    ]
  },
  "govAtlasGraph": {
    "description": "The core: every government unit encoded as :gov.unit/* (recursive :gov.unit/parent tree) with :gov.address/* (住所), :gov.window/* (窓口), :gov.form/* (書式), :gov.procedure/* (手続き), :gov.bpmn/* (BPMN), per 00-contracts/schemas/gov-atlas-ontology.kotoba.edn. Seed at registry/gov-units.seed.edn.",
    "schemaFile": "/00-contracts/schemas/gov-atlas-ontology.kotoba.edn",
    "seedFile": "/20-actors/ooyake/registry/gov-units.seed.edn",
    "seedProofChain": "gov.jpn → 財務省 → 国税庁 → 東京国税局 → 麹町税務署 (住所+窓口); 東京都 → 新宿区 → 戸籍住民課窓口 (住所); + USA Treasury/IRS, UK HMRC, DE, KR country/ministry rows; + EU supranational. 3 procedures (住民票/転入届/確定申告) with 書式 + BPMN + toritsugi-ref.",
    "graphName": "gov-atlas-v1",
    "coverageHonesty": "ALL seed rows ship :sourcing :representative + :verification-status :unverified-seed (G5). This is a PROOF-OF-MODEL, not coverage. Maturity reported per ADR-2605250680.",
    "verificationGate": "G5/G12 — no downstream action (toritsugi G14) on :unverified-seed/:representative; must be maintainer-verified (→ :authoritative) within the freshness window."
  },
  "cells": [
    {"name": "unit_registry", "module": "kotodama.cells.ooyake_unit_registry", "murakumoNode": "reuben", "phase": "continuous", "io": "maintain + resolve the :gov.unit/* administrative tree; enforce sourcing + verification-status"},
    {"name": "reconcile", "module": "kotodama.cells.ooyake_reconcile", "murakumoNode": "reuben", "phase": "event", "io": "reconcile units vs Wikidata QID / 行政機関コード / 全国地方公共団体コード / ISO-3166-2 / GeoNames (read-only ingest, G4)"},
    {"name": "address_ingest", "module": "kotodama.cells.ooyake_address_ingest", "murakumoNode": "gad", "phase": "event", "io": "ingest 住所 / hours / 窓口 from official sources → :gov.address/* + :gov.window/*"},
    {"name": "procedure_link", "module": "kotodama.cells.ooyake_procedure_link", "murakumoNode": "gad", "phase": "event", "io": "link :gov.procedure/* ↔ toritsugi registry + chigiri templates + :gov.bpmn/*"},
    {"name": "atlas_serve", "module": "kotodama.cells.ooyake_atlas_serve", "murakumoNode": "naphtali", "phase": "continuous", "io": "THE ONLY outward cell — serve per-unit civic-atlas profile + READ-ONLY XRPC (getUnit/resolvePath/findService/searchUnits); never mutates a gov record (G9)"},
    {"name": "freshness", "module": "kotodama.cells.ooyake_freshness", "murakumoNode": "naphtali", "phase": "continuous", "io": "re-verify within freshness window; flag :stale (G12)"},
    {"name": "world_model", "module": "kotodama.cells.ooyake_world_model", "murakumoNode": "reuben", "phase": "event", "io": "cross-actor world-model reconcile — join :gov.unit/* (structure) to tsumugi :organism/* (karma) over the shared :gov.unit/organism id-space; classify each POWER-BEARING unit confirmed/derived/dangling/proposed (local 窓口/ward/division excluded by construction, G1/G10) → out/world-model.kotoba.edn (read-side proposal, G9; live write-back Council+operator gated)"}
  ],
  "lexiconNamespaces": [
    "com.etzhayyim.ooyake.govUnit",
    "com.etzhayyim.ooyake.address",

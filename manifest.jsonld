  "constitutionalGates": {
    "description": "12 immutable gates per ADR-2606021600 §4. Council Lv6+ supermajority + new ADR to amend.",
    "gates": {
      "G1": "Charter Rider §2(a)-(h) scan on every authored artifact + outbound fetch",
      "G2": "kotoba attestation lineage on every datom (EAVT; no RW)",
      "G3": "Observational mirror only — atlas DID never claims to BE the gov, never an official channel, never issues/accepts on a gov's behalf (§2(c) impersonation ban)",
      "G4": "Public-data-only — only public official sources; respect robots.txt / ToS / rate-limits; no behind-auth access / circumvention",
      "G5": "Non-fabrication — provenance + last-verified + sourcing on every row; :representative never counted as coverage; procedures cite legal-basis",
      "G6": "No personal data — gov org data + public role-contact only; never an official's private/home contact; data-minimized",
      "G7": "Murakumo-only inference (ADR-2605215000)",
      "G8": "Non-commercial — public good; no resale as a data product (Charter Rider §2(e))",
      "G9": "Read-side only — never files/submits/mutates a gov record (→ toritsugi, gated); never audits/adjudicates (→ danjo)",
      "G10": "Civic wayfinding, never a target-list — never an attack-surface / SPOF / weak-point map of the state (§1.12 Transparent Force)",
      "G11": "Neutrality — jurisdiction-neutral + politically neutral; descriptive; no ranking of governments",
      "G12": "Freshness-gated — stale flagged :stale; downstream (toritsugi G14) must re-verify before any citizen-facing action"
    }
  },
  "nonGoals": {
    "description": "11 explicitly excluded scopes",
    "goals": {
      "N1": "NOT a government / official 自治体・省庁 channel (observational mirror only, G3)",
      "N2": "NOT a filing / submission actor (that is toritsugi, gated)",
      "N3": "NOT an oversight / audit / adjudication actor (that is danjo)",
      "N4": "NOT a fiscal-flow visualizer (that is kanae)",
      "N5": "NOT a 縁/取 karma power-graph (that is tsumugi; reconciles via :gov.unit/organism)",
      "N6": "NOT an attack-surface / SPOF / weak-point map of the state (G10)",
      "N7": "NOT a store of officials' personal data (G6)",
      "N8": "NOT a data-broker / resold data product (G8)",
      "N9": "NOT a 行政書士 / 弁護士 firm or legal/tax advice (→ chigiri / toritate / licensed)",
      "N10": "NOT a closed-source / secret-method engine",
      "N11": "NOT complete coverage (R0 is a proof-of-model; coverage gated by :sourcing)"
    }
  },
  "roadmap": [
    {"phase": "R0", "date": "2026-06-02", "scope": "Ontology + manifest + README + CLAUDE.md + MATURITY.md + gov-units.seed.edn proof-of-model (JP 財務省→国税庁→東京国税局→麹町税務署 + 東京都→新宿区→窓口 + USA/GBR/DEU/KOR/EU rows, all unverified-seed) + 8 Lexicon skeletons + 3 BPMN (model-only). NO cell runs, NO live ingest, NO served DIDs.", "murakumoFleet": "No deployment", "gate": "ADR-2606021600 (PROPOSED)"},
    {"phase": "R1", "date": "post-Bootstrap-Council + Council Lv6+ ≥3", "scope": "unit_registry + reconcile live; ingest JP authoritative registries (行政機関コード / 全国地方公共団体コード) → :authoritative; atlas_serve serves searchUnits; /actors search surfaces gov units.", "murakumoFleet": "reuben", "gate": "Council Lv6+ ≥3"},
    {"phase": "R2", "date": "post-R1", "scope": "address_ingest + procedure_link; per-unit civic-atlas did.json served dynamically (kotoba → KV, ADR-2606013800 pattern); findService end-to-end for JP.", "murakumoFleet": "reuben + gad", "gate": "Council Lv6+ ≥4"},
    {"phase": "R3", "date": "post-R2 + 30-day public comment", "scope": "multi-jurisdiction ingest at scale; GeoJSON footprints; danjo/kanae/tsumugi/toritsugi/himotoki consume the live atlas.", "murakumoFleet": "Full 10-node fleet", "gate": "Council Lv6+ ≥4 + 30-day public comment"}
  ],

{
  "lexicon": 1,
  "id": "com.etzhayyim.ooyake.getUnit",
  "description": "READ-ONLY (G9). Resolve a government unit and (optionally) its immediate children, addresses, windows and owned procedures from the gov-atlas kotoba graph. Served by ooyake's atlas_serve cell over EAVT/AVET arrangements. No mutation, no government interaction.",
  "defs": {
    "main": {
      "type": "query",
      "parameters": {
        "type": "params",
        "required": ["unit"],
        "properties": {
          "unit": {"type": "string", "description": "unitId (gov.jpn.mof) OR atlasDid (did:web:etzhayyim.com:gov:jpn:ministry:mof)"},
          "includeChildren": {"type": "boolean", "default": false},
          "includeAddresses": {"type": "boolean", "default": true},
          "includeWindows": {"type": "boolean", "default": true},
          "includeProcedures": {"type": "boolean", "default": false}
        }
      },
      "output": {
        "encoding": "application/json",
        "schema": {
          "type": "object",
          "required": ["unit"],
          "properties": {
            "unit": {"type": "ref", "ref": "com.etzhayyim.ooyake.govUnit"},
            "children": {"type": "array", "items": {"type": "ref", "ref": "com.etzhayyim.ooyake.govUnit"}},
            "addresses": {"type": "array", "items": {"type": "ref", "ref": "com.etzhayyim.ooyake.address"}},
            "windows": {"type": "array", "items": {"type": "ref", "ref": "com.etzhayyim.ooyake.window"}},
            "procedures": {"type": "array", "items": {"type": "ref", "ref": "com.etzhayyim.ooyake.procedure"}}
          }
        }
      }
    }
  }
}

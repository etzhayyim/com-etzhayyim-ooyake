{:lexicon 1,
 :id "com.etzhayyim.ooyake.resolvePath",
 :description
 "READ-ONLY (G9). Resolve a dotted unit path or an atlas DID into the full ancestor chain (root → leaf), walking :gov.unit/parent. Backs breadcrumb wayfinding and the per-unit civic-atlas DID-document resolution.",
 :defs
 {:main
  {:type "query",
   :parameters
   {:type "params",
    :required ["path"],
    :properties
    {:path
     {:type "string",
      :description "unitId (gov.jpn.mof.nta) OR atlasDid"}}},
   :output
   {:encoding "application/json",
    :schema
    {:type "object",
     :required ["chain"],
     :properties
     {:chain
      {:type "array",
       :items {:type "ref", :ref "com.etzhayyim.ooyake.govUnit"},
       :description "ancestor chain root → leaf"}}}}}}}

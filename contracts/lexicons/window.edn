{:lexicon 1,
 :id "com.etzhayyim.ooyake.window",
 :description
 "A 窓口 (service counter / contact point) of a government unit in the world government atlas (ADR-2606021600). The citizen-wayfinding edge: a window `handles` a set of procedures at an `addressId`. G6: public role-contact only. Projection of the :gov.window/* kotoba vocabulary.",
 :defs
 {:main
  {:type "record",
   :key "any",
   :record
   {:type "object",
    :required
    ["windowId"
     "unitId"
     "addressId"
     "nameLocal"
     "channel"
     "sourcing"
     "provenance"
     "lastVerified"],
    :properties
    {:lastVerified {:type "string", :format "datetime"},
     :addressId
     {:type "string",
      :description "addressId where the window is located"},
     :channel
     {:type "array",
      :items
      {:type "string",
       :knownValues ["in-person" "phone" "online" "mail" "kiosk"]}},
     :windowId {:type "string"},
     :nameEn {:type "string"},
     :url
     {:type "string",
      :format "uri",
      :description
      "online window/portal URL if channel includes online"},
     :provenance {:type "string", :format "uri"},
     :hours {:type "string"},
     :appointmentRequired {:type "boolean"},
     :sourcing
     {:type "string", :knownValues ["authoritative" "representative"]},
     :unitId
     {:type "string", :description "unitId that operates this window"},
     :handles
     {:type "array",
      :items {:type "string"},
      :description "procedureId list this window serves"},
     :nameLocal
     {:type "string", :description "窓口/課 name, e.g. 戸籍住民課 住民記録係"}}}}}}

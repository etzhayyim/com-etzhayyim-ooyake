{:lexicon 1,
 :id "com.etzhayyim.ooyake.govUnit",
 :description
 "An OBSERVATIONAL MIRROR record of a real government unit in the world government atlas (ADR-2606021600). CONSTITUTIONAL (G3, §2(c)): this record MIRRORS a real public body — it NEVER claims to BE the government, is NEVER an official channel, and issues/accepts NOTHING on a government's behalf. `atlasDid` (did:web:etzhayyim.com:gov:<iso3>:...) is the etzhayyim mirror identifier; `officialDid`/`officialUrl` point at the body itself. Non-fabrication (G5): `sourcing` + `provenance` + `lastVerified` mandatory; `representative` rows are illustrative, never counted as coverage. Projection of the :gov.unit/* kotoba vocabulary.",
 :defs
 {:main
  {:type "record",
   :key "any",
   :record
   {:type "object",
    :required
    ["unitId"
     "atlasDid"
     "level"
     "jurisdiction"
     "nameLocal"
     "sourcing"
     "provenance"
     "lastVerified"
     "verificationStatus"],
    :properties
    {:organismRef
     {:type "string",
      :description
      ":organism/id (engi) for the tsumugi 縁/取 power-graph reconciliation"},
     :cofog
     {:type "array",
      :items {:type "string"},
      :description "UN COFOG functional code(s)"},
     :externalCode
     {:type "array",
      :items {:type "string"},
      :description
      "prefixed reconciliation keys, e.g. jp-jichitai:131041 / iso3166-2:JP-13"},
     :officialUrl {:type "string", :format "uri"},
     :lastVerified {:type "string", :format "datetime"},
     :jurisdiction
     {:type "string",
      :maxLength 12,
      :description
      "ISO-3166: iso3 [+ -subdivision], e.g. jpn / jpn-13"},
     :geo
     {:type "string",
      :description
      "IPFS CID of GeoJSON boundary OR 'lat,lon' centroid"},
     :nameRomanized {:type "string"},
     :officialDid
     {:type "string",
      :format "did",
      :description
      "the government's OWN DID if it publishes one (mirrored, never minted by us)"},
     :level
     {:type "string",
      :knownValues
      ["supranational"
       "country"
       "region"
       "subdivision"
       "prefecture"
       "municipality"
       "ward"
       "ministry"
       "agency"
       "bureau"
       "division"
       "section"
       "madoguchi"]},
     :nameEn {:type "string"},
     :status
     {:type "string",
      :knownValues ["active" "reorganized" "superseded" "dissolved"]},
     :provenance
     {:type "string",
      :format "uri",
      :description "G5 mandatory source"},
     :wikidata {:type "string", :description "Wikidata QID"},
     :sourcing
     {:type "string",
      :knownValues ["authoritative" "representative"],
      :description "G5 — representative NEVER counted as coverage"},
     :unitId
     {:type "string",
      :description
      "stable dotted key, e.g. gov.jpn.mof.nta.tokyo.kojimachi"},
     :nameLocal {:type "string"},
     :verificationStatus
     {:type "string",
      :knownValues ["unverified-seed" "maintainer-verified" "stale"]},
     :branch
     {:type "string",
      :knownValues
      ["executive"
       "legislative"
       "judicial"
       "independent"
       "local"
       "intergovernmental"]},
     :parentId
     {:type "string",
      :description
      "unitId of the parent node (absent for supranational / top country)"},
     :atlasDid
     {:type "string",
      :format "did",
      :description
      "etzhayyim civic-atlas MIRROR DID — observational, NEVER claims to be the gov (G3)"}}}}}}

{:lexicon 1,
 :id "com.etzhayyim.ooyake.procedure",
 :description
 "The ATLAS view of a 手続き (administrative procedure): who owns it, where it is filed, what form it needs, its BPMN. This is the STRUCTURAL/catalog view — the citizen-execution view (guide/draft/submit/track) lives in com.etzhayyim.toritsugi.procedure, linked via `toritsugiRef`. ooyake catalogs; toritsugi delivers (G9 — ooyake never files). G5: legalBasis + provenance + sourcing mandatory. Projection of the :gov.procedure/* kotoba vocabulary.",
 :defs
 {:main
  {:type "record",
   :key "any",
   :record
   {:type "object",
    :required
    ["procedureId"
     "titleLocal"
     "ownerUnitId"
     "jurisdiction"
     "legalBasis"
     "channel"
     "sourcing"
     "provenance"
     "lastVerified"
     "verificationStatus"],
    :properties
    {:fee
     {:type "string",
      :description "fee incl. currency + variance note"},
     :procedureId {:type "string"},
     :lastVerified {:type "string", :format "datetime"},
     :jurisdiction {:type "string", :maxLength 12},
     :statutoryDays
     {:type "integer", :description "法定処理期間 in days (0 = 即日)"},
     :ownerUnitId
     {:type "string",
      :description "unitId of the owning authority (所管)"},
     :onlineUrl {:type "string", :format "uri"},
     :channel
     {:type "array",
      :items
      {:type "string",
       :knownValues ["in-person" "online" "mail" "kiosk"]}},
     :formIds
     {:type "array",
      :items {:type "string"},
      :description ":gov.form/id list (書式)"},
     :legalBasis
     {:type "string", :description "根拠法令 — MANDATORY (G5)"},
     :toritsugiRef
     {:type "string",
      :description
      "procedureId in toritsugi's registry (delivery handoff)"},
     :windowIds
     {:type "array",
      :items {:type "string"},
      :description ":gov.window/id list (窓口)"},
     :titleLocal {:type "string"},
     :provenance {:type "string", :format "uri"},
     :sourcing
     {:type "string", :knownValues ["authoritative" "representative"]},
     :requiredDocs {:type "array", :items {:type "string"}},
     :verificationStatus
     {:type "string",
      :knownValues ["unverified-seed" "maintainer-verified" "stale"]},
     :titleEn {:type "string"},
     :bpmnId
     {:type "string", :description ":gov.bpmn/id process model"}}}}}}
